# Resend API key for sending contact form emails
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=

# Google reCAPTCHA v3 secret key (server-side)
# Get yours at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=

# Google reCAPTCHA v3 site key (client-side)
# Used in the contact form
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Site URL for sitemap, OG images, and canonical URLs
# In development: http://localhost:3000
# In production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=

